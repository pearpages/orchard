{
  "name": "orchard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:e2e": "pnpm -r --workspace-concurrency=1 test:e2e",
    "sites": "pnpm -r --parallel --filter \"./plugins/*/site\" --filter \"./sites/*\" dev",
    "sites:build": "pnpm --filter \"./sites/*\" --filter \"./plugins/*/site\" build && node scripts/assemble-site.mjs",
    "sites:preview": "node scripts/serve-site.mjs",
    "sites:og": "node scripts/generate-og.mjs",
    "begone": "pnpm --filter \"./plugins/begone/**\"",
    "cookiejar": "pnpm --filter \"./plugins/cookiejar/**\"",
    "focaccia": "pnpm --filter \"./plugins/focaccia/**\"",
    "headerforge": "pnpm --filter \"./plugins/headerforge/**\"",
    "hopchase": "pnpm --filter \"./plugins/hopchase/**\""
  }
}
