{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node", "chrome"]
  },
  "include": ["vite.config.ts", "manifest.config.ts", "playwright.config.ts", "e2e"]
}
