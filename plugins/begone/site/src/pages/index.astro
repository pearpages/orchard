---
import '../styles/theme.css';
import Layout from '@browser-plugins/site-kit/components/Layout.astro';
import InstallSteps from '@browser-plugins/site-kit/components/InstallSteps.astro';
import OtherPlugins from '@browser-plugins/site-kit/components/OtherPlugins.astro';
import AuthorCard from '@browser-plugins/site-kit/components/AuthorCard.astro';
---

<Layout
  title="Begone — banish unwanted elements"
  description="Banishes unwanted elements the instant they appear. Add the CSS selectors of cookie banners, newsletter popups and other page noise — Begone removes them on every page, live."
>
  <header class="hero">
    <h1 class="hero__title">Begone<span class="hero__zap">.</span></h1>
    <p class="hero__tagline">Banishes unwanted elements the instant they appear.</p>
    <p class="hero__pitch">
      Begone ships with <strong>no rules of its own</strong>. You add the CSS selectors — cookie
      banners, newsletter popups, chat bubbles — and they vanish from every page, the moment they
      appear.
    </p>
    <a class="hero__cta" href="#install">Banish something</a>

    <figure class="page" aria-label="A page's DOM with the cookie banner and newsletter popup removed by Begone">
      <figcaption class="page__bar">
        <span class="page__dot"></span><span class="page__dot"></span><span class="page__dot"></span>
        <span class="page__url">somewhere-noisy.example</span>
      </figcaption>
      <pre class="page__dom"><code><span class="line">&lt;main class="article"&gt;</span>
<span class="line line--gone">  &lt;div class="cookie-banner"&gt;We value your privacy…&lt;/div&gt;</span>
<span class="line">  &lt;h1&gt;The thing you actually came to read&lt;/h1&gt;</span>
<span class="line">  &lt;p&gt;Lorem ipsum dolor sit amet…&lt;/p&gt;</span>
<span class="line line--gone">  &lt;aside id="newsletter-popup"&gt;Join our newsletter!&lt;/aside&gt;</span>
<span class="line">&lt;/main&gt;</span></code></pre>
      <ul class="page__rules">
        <li class="page__rule"><code>.cookie-banner</code><b>✕ banished</b></li>
        <li class="page__rule"><code>#newsletter-popup</code><b>✕ banished</b></li>
      </ul>
    </figure>
  </header>

  <main class="features">
    <section class="card">
      <h2 class="card__title">Your rules only</h2>
      <p class="card__body">
        The selector list starts empty and lives in your browser. Nothing is removed until you say
        so — Begone is a neutral tool with your taste applied.
      </p>
    </section>
    <section class="card">
      <h2 class="card__title">Gone the instant it appears</h2>
      <p class="card__body">
        A MutationObserver watches the page, so elements injected late — the popup that slides in
        after three paragraphs — are removed the moment they land in the DOM.
      </p>
    </section>
    <section class="card">
      <h2 class="card__title">Any CSS selector</h2>
      <p class="card__body">
        If <code class="inline">querySelector</code> can find it, Begone can remove it.
        <code class="inline">.cookie-banner</code>, <code class="inline">#newsletter-popup</code>,
        <code class="inline">[data-testid="paywall-overlay"]</code> — one per entry.
      </p>
    </section>
    <section class="card">
      <h2 class="card__title">Edits apply live</h2>
      <p class="card__body">
        Add or delete a selector in the popup and every open tab reacts immediately through
        <code class="inline">storage.onChanged</code> — no reload, no re-visit.
      </p>
    </section>
    <section class="card">
      <h2 class="card__title">Follows your Chrome</h2>
      <p class="card__body">
        The list is stored in <code class="inline">chrome.storage.sync</code>, so your banishments
        travel with your profile to every machine you sign into.
      </p>
    </section>
    <section class="card">
      <h2 class="card__title">Tiny and honest</h2>
      <p class="card__body">
        One permission (<code class="inline">storage</code>), no network calls, no analytics, a
        content script of about a kilobyte. Small enough to read in one sitting.
      </p>
    </section>
  </main>

  <InstallSteps
    buildCommand="pnpm --filter @begone/extension build"
    distPath="plugins/begone/extension/dist"
  />

  <OtherPlugins current="begone" />

  <AuthorCard>
    <p>Dedicated to Christophe, who wanted the noise gone.</p>
  </AuthorCard>
</Layout>

<style>
  .hero {
    max-width: 760px;
    margin: 0 auto;
    padding: 56px 24px 56px;
    text-align: center;
  }

  .hero__title {
    margin: 0;
    font-size: clamp(40px, 7vw, 56px);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .hero__zap {
    color: var(--be-accent);
  }

  .hero__tagline {
    margin: 8px 0 0;
    font-size: 18px;
    color: var(--be-ink-muted);
  }

  .hero__pitch {
    max-width: 560px;
    margin: 24px auto 0;
    font-size: 18px;
  }

  .hero__cta {
    display: inline-block;
    margin-top: 24px;
    padding: 12px 32px;
    border-radius: 999px;
    background: var(--be-accent);
    color: #fff8f6;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 2px 0 var(--be-accent-text);
  }

  .hero__cta:hover {
    background: var(--be-accent-text);
  }

  .page {
    margin: 44px 0 0;
    text-align: left;
    background: var(--be-surface);
    border: 1px solid var(--be-border);
    border-radius: 12px;
    box-shadow: 0 6px 18px var(--be-shadow);
    overflow: hidden;
  }

  .page__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--be-bg);
    border-bottom: 1px solid var(--be-border);
  }

  .page__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--be-border-strong);
  }

  .page__url {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--be-ink-muted);
  }

  .page__dom {
    margin: 0;
    padding: 18px 20px;
    font-family: var(--font-mono);
    font-size: 13.5px;
    line-height: 1.7;
    overflow-x: auto;
  }

  .line {
    display: block;
    white-space: pre;
  }

  .line--gone {
    color: var(--be-ink-muted);
    text-decoration: line-through;
    text-decoration-color: var(--be-accent);
    text-decoration-thickness: 2px;
    opacity: 0.6;
  }

  .page__rules {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0 20px 18px;
    list-style: none;
  }

  .page__rule {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 12px;
    background: var(--be-accent-soft);
    border-radius: 999px;
    font-size: 12.5px;
  }

  .page__rule code {
    font-family: var(--font-mono);
    color: var(--be-ink);
  }

  .page__rule b {
    color: var(--be-accent-text);
    font-weight: 700;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px 48px;
  }

  .card {
    padding: 26px 28px;
    background: var(--be-surface);
    border: 1px solid var(--be-border);
    border-radius: 10px;
    box-shadow: 0 3px 10px var(--be-shadow);
  }

  .card__title {
    margin: 0;
    font-size: 19px;
    color: var(--be-accent-text);
  }

  .card__body {
    margin: 10px 0 0;
    font-size: 15px;
  }

  .inline {
    padding: 1px 5px;
    background: var(--be-accent-soft);
    border-radius: 5px;
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--be-accent-text);
  }
</style>
