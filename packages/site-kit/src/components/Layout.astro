---
import pearIcon from '@browser-plugins/assets/pearpages-icon.png';

interface Props {
  title: string;
  description: string;
  /** Favicon href; defaults to the shared pear icon. */
  favicon?: string;
}

const { title, description, favicon = pearIcon.src } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={favicon} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <link rel="canonical" href={canonical} />}
    {canonical && <meta property="og:url" content={canonical} />}
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
